@{
    ViewData["Title"] = "Trang chủ";
}

<div class="chat-layout glass-effect mt-3">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header d-flex flex-column p-3 border-bottom border-secondary">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h5 class="m-0 text-white">Tin nhắn</h5>
                <div>
                    <button class="btn btn-sm btn-outline-info me-1" data-bs-toggle="modal" data-bs-target="#searchUserModal" title="Tìm kiếm & Kết bạn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/></svg>
                    </button>
                    <button class="btn btn-sm btn-outline-light" data-bs-toggle="modal" data-bs-target="#newChatModal" title="Tạo trò chuyện mới">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
        <div class="sidebar-body p-2 custom-scrollbar" id="conversationList">
            <!-- Danh sách hội thoại load qua JS -->
            <div class="text-center text-muted mt-3">Đang tải...</div>
        </div>
    </div>

    <!-- Chat Area -->
    <div class="chat-area" id="chatArea">
        <div class="chat-empty-state d-flex flex-column justify-content-center align-items-center h-100 text-muted">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="bi bi-chat-dots opacity-50 mb-3" viewBox="0 0 16 16">
                <path d="M5 8a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm4 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm3 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
                <path d="m2.165 15.803.02-.004c1.83-.363 2.948-.842 3.468-1.105A9.06 9.06 0 0 0 8 15c4.418 0 8-3.134 8-7s-3.582-7-8-7-8 3.134-8 7c0 1.76.743 3.37 1.97 4.6a10.437 10.437 0 0 1-.524 2.318l-.003.011a10.722 10.722 0 0 1-.244.637c-.079.186.074.394.273.362a21.673 21.673 0 0 0 .693-.125zm.8-3.108a1 1 0 0 0-.287-.801C1.618 10.83 1 9.468 1 8c0-3.192 3.004-6 7-6s7 2.808 7 6-3.004 6-7 6a8.06 8.06 0 0 1-2.088-.272 1 1 0 0 0-.711.074c-.387.196-1.24.57-2.634.893a10.97 10.97 0 0 0 .398-2z"/>
            </svg>
            <h5>Bạn chưa chọn cuộc trò chuyện nào</h5>
            <p>Hãy chọn một cuộc hội thoại hoặc bắt đầu mới!</p>
        </div>
        
        <div class="chat-active-state d-none h-100 flex-column">
            <!-- Header -->
            <div class="chat-header d-flex justify-content-between align-items-center p-3 border-bottom border-secondary">
                <div class="d-flex align-items-center">
                    <img src="/img/default_avatar.png" class="rounded-circle me-2" width="40" height="40" id="currentChatAvatar">
                    <div>
                        <h6 class="m-0 text-white" id="currentChatName">Tên người dùng</h6>
                        <small class="text-muted" id="currentChatStatus">Đang hoạt động</small>
                    </div>
                </div>
                <!-- Advanced actions -->
                <div class="chat-actions d-flex align-items-center">
                    <button class="btn btn-sm btn-outline-secondary me-1" id="muteNotifyBtn" onclick="toggleMute()" title="Tắt thông báo">
                        <i class="bi bi-bell" id="muteIcon"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-warning me-1 d-none" id="groupSettingsBtn" onclick="openGroupSettings()" title="Cài đặt Nhóm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-gear" viewBox="0 0 16 16"><path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z"/><path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.764-.415 1.6.42 1.184 1.185l-.159.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.415.764-.42 1.6-1.185 1.184l-.291-.159a1.873 1.873 0 0 0-2.693 1.116l-.094.318c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.184-1.185l.159-.291A1.873 1.873 0 0 0 1.945 8.93l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094A1.873 1.873 0 0 0 3.06 4.377l-.16-.292c-.415-.764.42-1.6 1.185-1.184l.292.159a1.873 1.873 0 0 0 2.692-1.115l.094-.319z"/></svg>
                    </button>
                    <button class="btn btn-sm btn-outline-info me-1" id="voiceCallBtn" title="Cuộc gọi thoại" onclick="startCall(false)"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-telephone" viewBox="0 0 16 16"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328zM1.884.511a1.745 1.745 0 0 1 2.612.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511z"/></svg></button>
                    <button class="btn btn-sm btn-outline-success" id="videoCallBtn" title="Cuộc gọi video" onclick="startCall(true)"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-camera-video" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M0 5a2 2 0 0 1 2-2h7.5a2 2 0 0 1 1.983 1.738l3.11-1.382A1 1 0 0 1 16 4.269v7.462a1 1 0 0 1-1.406.913l-3.111-1.382A2 2 0 0 1 9.5 13H2a2 2 0 0 1-2-2V5zm11.5 5.175 3.5 1.556V4.269l-3.5 1.556v4.35zM2 4a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h7.5a1 1 0 0 0 1-1V5a1 1 0 0 0-1-1H2z"/></svg></button>
                </div>
            </div>

            <!-- Messages -->
            <div class="chat-messages p-3 flex-grow-1 custom-scrollbar d-flex flex-column gap-3" id="messagesList">
            </div>

            <!-- Input form -->
            <div class="chat-input p-3 border-top border-secondary">
                <form id="sendMessageForm" class="d-flex gap-2 align-items-center">
                    <input type="hidden" id="activeConversationId">
                    <button type="button" class="btn btn-secondary fs-5 p-1 px-2" title="Gửi File" onclick="document.getElementById('fileInput').click()">
                        <i class="bi bi-paperclip"></i>
                    </button>
                    <input type="file" id="fileInput" class="d-none" onchange="uploadFile(this)">
                    
                    <button type="button" class="btn btn-danger fs-5 p-1 px-2" id="recordAudioBtn" title="Ghi âm" onmousedown="startRecording()" onmouseup="stopRecording()">
                        <i class="bi bi-mic"></i>
                    </button>

                    <input type="text" id="messageInput" class="form-control bg-dark border-secondary text-white" placeholder="Nhập tin nhắn..." autocomplete="off">
                    <button type="submit" class="btn btn-primary px-4">Gửi</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Create Chat -->
<div class="modal fade" id="newChatModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark text-white border-secondary">
      <div class="modal-header border-secondary">
        <h5 class="modal-title">Tạo trò chuyện mới</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
          <ul class="nav nav-tabs mb-3 border-secondary" id="chatTypeTab" role="tablist">
              <li class="nav-item" role="presentation">
                  <button class="nav-link active bg-transparent text-white" id="private-tab" data-bs-toggle="tab" data-bs-target="#private" type="button" role="tab" >Cá nhân</button>
              </li>
              <li class="nav-item" role="presentation">
                  <button class="nav-link bg-transparent text-white" id="group-tab" data-bs-toggle="tab" data-bs-target="#group" type="button" role="tab">Nhóm / Kênh</button>
              </li>
          </ul>
          <div class="tab-content" id="chatTypeTabContent">
              <!-- Private Chat -->
              <div class="tab-pane fade show active" id="private" role="tabpanel">
                  <p class="text-muted">Chọn một người để nhắn tin.</p>
                  <div class="list-group list-group-flush border-secondary" id="userList">
                  </div>
              </div>
              <!-- Group Chat -->
              <div class="tab-pane fade" id="group" role="tabpanel">
                  <form id="createGroupForm">
                      <div class="mb-3">
                          <label class="form-label">Tên Nhóm / Kênh</label>
                          <input type="text" id="groupName" class="form-control bg-dark text-white border-secondary" placeholder="Tên nhóm mới..." required>
                      </div>
                      <div class="mb-3 form-check">
                          <input type="checkbox" class="form-check-input" id="isChannel">
                          <label class="form-check-label" for="isChannel">Tạo Kênh (1 chiều: Chỉ Admin mới có thể gửi tin nhắn)</label>
                      </div>
                      <p class="text-muted mb-2">Thêm thành viên:</p>
                      <div class="user-select-list mb-3 custom-scrollbar" style="max-height: 200px; overflow-y: auto;" id="groupUserList">
                      </div>
                      <button type="submit" class="btn btn-primary w-100">Tạo mới</button>
                  </form>
              </div>
          </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal Call (Incoming / Outgoing) -->
<div class="modal fade" id="callModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content bg-dark text-white border-secondary">
      <div class="modal-header border-secondary">
        <h5 class="modal-title" id="callModalTitle">Đang gọi...</h5>
      </div>
      <div class="modal-body text-center">
          <p id="callStatusText">Đang chờ kết nối...</p>
          <div class="d-flex justify-content-center gap-2 mb-3">
              <video id="remoteVideo" autoplay playsinline style="width: 100%; max-width: 400px; background: #000; border-radius: 8px;"></video>
              <video id="localVideo" autoplay playsinline muted style="width: 150px; background: #222; border-radius: 8px; position: absolute; bottom: 20px; right: 20px; border: 2px solid #555;"></video>
          </div>
      </div>
      <div class="modal-footer border-secondary justify-content-center" id="callActions">
          <button type="button" class="btn btn-success d-none" id="acceptCallBtn" onclick="acceptCall()">Nghe</button>
          <button type="button" class="btn btn-danger" id="endCallBtn" onclick="endCall()">Kết thúc</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal Search User -->
<div class="modal fade" id="searchUserModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark text-white border-secondary">
      <div class="modal-header border-secondary">
        <h5 class="modal-title">Tìm kiếm & Kết bạn</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
          <div class="input-group mb-3">
              <input type="text" id="searchInput" class="form-control bg-dark border-secondary text-white" placeholder="Nhập tên hoặc username...">
              <button class="btn btn-outline-info" type="button" onclick="performSearch()">Tìm</button>
          </div>
          <div class="list-group list-group-flush border-secondary custom-scrollbar" id="searchResults" style="max-height: 300px; overflow-y: auto;">
              <p class="text-muted text-center mt-2">Nhập từ khóa để tìm kiếm...</p>
          </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal User Profile -->
<div class="modal fade" id="userProfileModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content bg-dark text-white border-secondary">
      <div class="modal-header border-secondary">
        <h5 class="modal-title">Hồ sơ người dùng</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center" id="profileContent">
          <!-- Load by JS -->
      </div>
    </div>
  </div>
</div>

<!-- Modal Group Settings -->
<div class="modal fade" id="groupSettingsModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark text-white border-secondary">
      <div class="modal-header border-secondary">
        <h5 class="modal-title">Quản lý Nhóm</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="groupSettingsContent">
          <div id="groupAdminControls" class="d-none mb-3 p-3 border border-warning rounded">
              <h6 class="text-warning">Quyền Quản trị</h6>
              <div class="form-check form-switch mt-2">
                  <input class="form-check-input" type="checkbox" id="readonlySwitch" onchange="toggleReadOnly(this.checked)">
                  <label class="form-check-label" for="readonlySwitch">Chế độ Kênh (Chỉ Quản trị viên mới được nhắn)</label>
              </div>
          </div>
          
          <h6>Thành viên</h6>
          <div class="list-group list-group-flush border-secondary custom-scrollbar" id="groupMembersList" style="max-height: 250px; overflow-y: auto;">
              <!-- Load bằng JS -->
          </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        var currentUserId = "@Context.User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value";
    </script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}